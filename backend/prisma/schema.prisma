datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Schema {
  id             String   @id @default(uuid())
  subjectPattern String   @unique
  schema         Json     // The JSON Schema definition
  version        Int      @default(1)
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DlqEvent {
  id            String   @id @default(uuid())
  stream        String
  subject       String
  consumerGroup String
  payload       Json
  headers       Json?
  errorReason   String
  numDelivered  Int
  status        String   // PENDING, REPLAYED, DISMISSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ConsumerSimulatorConfig {
  id              String   @id @default(uuid())
  stream          String
  subject         String
  durableName     String   @unique
  successRate     Float    // e.g. 0.8
  processingDelay Int      // simulated delay in ms
  maxDeliver      Int      @default(3)
  active          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
