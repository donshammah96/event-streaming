datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Application-level enum for DLQ event lifecycle state.
/// Matching values are enforced both here and in the Supabase CHECK constraint
/// (setup.sql) so both the Express backend and Next.js dashboard share the same
/// status vocabulary.
enum DlqStatus {
  PENDING
  REPLAYED
  DISMISSED
}

model Schema {
  id             String   @id @default(uuid())
  subjectPattern String   @unique
  schema         Json     // The JSON Schema definition
  version        Int      @default(1)
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DlqEvent {
  id            String    @id @default(uuid())
  stream        String
  subject       String
  consumerGroup String
  payload       Json
  headers       Json?
  errorReason   String
  numDelivered  Int
  status        DlqStatus @default(PENDING) // typed enum replaces bare String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])          // query-performance index for status filter
  @@index([createdAt(sort: Desc)]) // supports date-range pagination
}

model ConsumerSimulatorConfig {
  id              String   @id @default(uuid())
  stream          String
  subject         String
  durableName     String   @unique
  successRate     Float    // e.g. 0.8
  processingDelay Int      // simulated delay in ms
  maxDeliver      Int      @default(3)
  active          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])          // supports active-only queries in stats polling
}
